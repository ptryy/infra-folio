# Copy to .env and fill in values before running `make dev`

# Runtime environment
ENVIRONMENT=local

# Feature flags (deploy-time, changing requires redeploy)
LIVE_TERMINAL=false
CONTACT_FORM=true

# MinIO — local dev only
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000

# MinIO client alias (used by mc in Makefile)
MINIO_ALIAS=local

# Production domain (used by og-gen and status targets)
# DOMAIN=yourdomain.com

# Cloudflare R2 public domain (prod only)
# MEDIA_PUBLIC_DOMAIN=assets.yourdomain.com

# GitHub token for api-worker (set as wrangler secret in prod)
# In local dev, set here and wrangler dev will pick it up from [vars]
GITHUB_TOKEN=

# Giscus (GitHub Discussions-backed blog comments)
# Get these values from https://giscus.app after configuring your repo
GISCUS_REPO=
GISCUS_REPO_ID=
GISCUS_CATEGORY_ID=

# media-upload / media-pull take a source/destination dir as SRC:
#   make media-upload SRC=./media
