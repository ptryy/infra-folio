# Copy to .env and fill in values before running `make dev`

# Runtime environment
ENVIRONMENT=local

# Feature flags (deploy-time, changing requires redeploy)
LIVE_TERMINAL=false
CONTACT_FORM=true

# MinIO — local dev only
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000

# MinIO client alias (used by mc in Makefile)
MINIO_ALIAS=local

# Production domain (used by og-gen and status targets)
# DOMAIN=yourdomain.com

# Cloudflare R2 public domain (prod only)
# MEDIA_PUBLIC_DOMAIN=assets.yourdomain.com

# GitHub token for api-worker.
# Prod: set as a Wrangler secret -> wrangler secret put GITHUB_TOKEN
# Local dev: wrangler dev does NOT read this .env; the api-worker reads the
#   token from workers/api/.dev.vars (wired up in a later task).
GITHUB_TOKEN=

# Giscus (GitHub Discussions-backed blog comments)
# Get these values from https://giscus.app after configuring your repo
GISCUS_REPO=
GISCUS_REPO_ID=
GISCUS_CATEGORY_ID=

# media-upload / media-pull take a source/destination dir as SRC:
#   make media-upload SRC=./media

# API worker base URL (used by LiveTerminal island)
API_BASE=http://localhost:8787
