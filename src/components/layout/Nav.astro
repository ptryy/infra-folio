---
import { getCollection } from 'astro:content'

// Derive functional targets for the mockup's "Blog Post" / "Project Detail"
// nav entries: link to the latest post and the featured (else first) project,
// falling back to the listing pages when a collection is empty.
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)
const projects = await getCollection('projects')
const latestPost = posts[0]
const featuredProject = projects.find((p) => p.data.featured) ?? projects[0]

const postHref = latestPost ? `/blog/${latestPost.slug}/` : '/blog/'
const projectHref = featuredProject ? `/projects/${featuredProject.slug}/` : '/projects/'

const links = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Blog Post', href: postHref },
  { label: 'Projects', href: '/projects/' },
  { label: 'Project Detail', href: projectHref },
]

const path = Astro.url.pathname
function isActive(href: string) {
  if (href === '/') return path === '/'
  return path === href || path.startsWith(href)
}
---
<nav class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">PHUC<b>::</b>TRUONG</a>
    <div class="nav__links">
      {links.map((l) => (
        <a href={l.href} class:list={['nav__btn', { active: isActive(l.href) }]}>{l.label}</a>
      ))}
    </div>
  </div>
</nav>

<style>
.nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(5, 6, 10, 0.82);
  backdrop-filter: blur(6px);
  border-bottom: 1px solid rgba(34, 227, 255, 0.25);
}
.nav__inner { display: flex; align-items: center; gap: 1rem; height: 64px; }
.nav__logo { font-weight: 700; font-size: 1.05rem; letter-spacing: 0.04em; color: var(--color-accent); text-decoration: none; }
.nav__logo b { color: var(--color-magenta); }
.nav__logo:hover { text-shadow: var(--glow-cyan); text-decoration: none; }
.nav__links { display: flex; gap: 0.4rem; margin-left: auto; flex-wrap: wrap; }
.nav__btn {
  font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.05em;
  text-transform: uppercase; color: var(--color-muted);
  background: transparent; border: 1px solid rgba(90, 107, 122, 0.4);
  padding: 0.4rem 0.7rem; border-radius: 3px; transition: 0.15s; text-decoration: none;
}
.nav__btn:hover { color: var(--color-accent); border-color: var(--color-accent); text-decoration: none; text-shadow: none; }
.nav__btn.active {
  color: var(--color-bg); background: var(--color-accent); border-color: var(--color-accent);
  box-shadow: 0 0 14px rgba(34, 227, 255, 0.6);
}
</style>
